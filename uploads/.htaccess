# Disable PHP execution in uploads directory
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Fallback: remove handler for PHP files
<FilesMatch "\.(php|phtml|php3|php4|php5|phps)$">
    SetHandler none
    ForceType text/plain
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
